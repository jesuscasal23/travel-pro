// ============================================================
// Travel Pro — Prisma Schema (Phase 1)
// Database: Supabase (PostgreSQL)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Profile — collected during onboarding
// ============================================================

model Profile {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id") // Supabase auth user ID
  nationality         String
  homeAirport         String   @map("home_airport")
  travelStyle         String   @map("travel_style")
  interests           String[]
  activityLevel       String?  @map("activity_level") // legacy column name; stores pace values ("relaxed" | "moderate" | "active")
  languagesSpoken     String[] @map("languages_spoken")
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  trips Trip[]

  @@map("profiles")
}

// ============================================================
// Trip — planning intent from questionnaire
// ============================================================

model Trip {
  id            String   @id @default(uuid())
  profileId     String?  @map("profile_id")
  profile       Profile? @relation(fields: [profileId], references: [id])

  tripType               String  @default("multi-city") @map("trip_type")
  region                 String  @default("")
  destination            String?
  destinationCountry     String? @map("destination_country")
  destinationCountryCode String? @map("destination_country_code")
  dateStart              String  @map("date_start")
  dateEnd       String   @map("date_end")
  flexibleDates Boolean  @default(false) @map("flexible_dates")
  travelers     Int      @default(2)
  description   String?
  shareToken    String?  @unique @map("share_token")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  itineraries     Itinerary[]
  affiliateClicks AffiliateClick[]

  @@index([profileId])
  @@map("trips")
}

// ============================================================
// Itinerary — AI-generated output, versioned
// ============================================================

model Itinerary {
  id    String @id @default(uuid())
  tripId String @map("trip_id")
  trip  Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  // Full itinerary (route + days + visa + weather) stored as JSON
  data Json

  version       Int     @default(1)
  isActive      Boolean @default(true) @map("is_active")
  promptVersion String  @default("v1") @map("prompt_version")

  // Generation job tracking
  generationStatus String  @default("pending") @map("generation_status") // pending | generating | complete | failed
  generationJobId  String? @map("generation_job_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  edits ItineraryEdit[]

  @@index([tripId])
  @@index([tripId, isActive])
  @@index([generationStatus])
  @@map("itineraries")
}

// ============================================================
// ItineraryEdit — audit log of edit actions
// ============================================================

model ItineraryEdit {
  id          String    @id @default(uuid())
  itineraryId String?   @map("itinerary_id")
  itinerary   Itinerary? @relation(fields: [itineraryId], references: [id], onDelete: SetNull)

  editType    String  @map("edit_type") // adjust_days | remove_city | reorder_cities | add_city | regenerate_activities
  editPayload Json    @map("edit_payload")
  description String?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([itineraryId])
  @@map("itinerary_edits")
}

// ============================================================
// AffiliateClick — affiliate link click tracking
// ============================================================

model AffiliateClick {
  id    String  @id @default(uuid())
  tripId String? @map("trip_id")
  trip  Trip?   @relation(fields: [tripId], references: [id], onDelete: SetNull)

  provider    String // skyscanner | booking | getyourguide
  clickType   String @map("click_type") // flight | hotel | activity
  city        String?
  destination String?
  url         String

  userId    String? @map("user_id")
  sessionId String? @map("session_id")
  ipHash    String? @map("ip_hash")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tripId])
  @@index([provider])
  @@index([createdAt])
  @@map("affiliate_clicks")
}

// ============================================================
// DiscoveredCity — cities found in AI output but missing from cities.ts
// ============================================================

model DiscoveredCity {
  id          String  @id @default(uuid())
  city        String
  country     String
  countryCode String  @map("country_code")
  lat         Float
  lng         Float

  timesProposed Int      @default(1) @map("times_proposed")
  firstTripId   String?  @map("first_trip_id")
  approved      Boolean  @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([city, countryCode], name: "city_country_unique")
  @@index([approved])
  @@map("discovered_cities")
}
