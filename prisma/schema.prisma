// ============================================================
// Travel Pro — Prisma Schema (Phase 1)
// Database: Supabase (PostgreSQL)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Profile — collected during onboarding
// ============================================================

model Profile {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id") // Supabase auth user ID
  nationality         String
  homeAirport         String   @map("home_airport")
  travelStyle         String   @map("travel_style")
  interests           String[]
  activityLevel       String   @default("moderate") @map("activity_level") // stores pace values ("relaxed" | "moderate" | "active")
  vibes               Json?    // VibeScores: { adventureComfort, socialQuiet, luxuryBudget, structuredSpontaneous, warmMixed } (0–100)
  languagesSpoken     String[] @map("languages_spoken")
  lastSeenAppVersion  String?  @map("last_seen_app_version")
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  isPremium           Boolean  @default(false) @map("is_premium")
  isSuperUser         Boolean  @default(false) @map("is_super_user")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  trips                Trip[]
  discoveredActivities DiscoveredActivity[]
  flightSelections     FlightSelection[]
  hotelSelections      HotelSelection[]

  @@map("profiles")
}

// ============================================================
// Trip — planning intent from questionnaire
// ============================================================

model Trip {
  id            String   @id @default(uuid())
  profileId     String?  @map("profile_id")
  profile       Profile? @relation(fields: [profileId], references: [id])

  tripType               String  @default("multi-city") @map("trip_type")
  region                 String  @default("")
  destination            String?
  destinationCountry     String? @map("destination_country")
  destinationCountryCode String? @map("destination_country_code")
  dateStart              String  @map("date_start")
  dateEnd       String   @map("date_end")
  travelers     Int      @default(2)
  description   String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  itineraries          Itinerary[]
  affiliateClicks      AffiliateClick[]
  discoveredActivities DiscoveredActivity[]
  flightSelections     FlightSelection[]
  hotelSelections      HotelSelection[]

  @@index([profileId])
  @@map("trips")
}

// ============================================================
// Itinerary — AI-generated output, versioned
// ============================================================

model Itinerary {
  id    String @id @default(uuid())
  tripId String @map("trip_id")
  trip  Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  // Full itinerary (route + days + visa + weather) stored as JSON
  data Json

  version       Int     @default(1)
  isActive      Boolean @default(true) @map("is_active")
  promptVersion String  @default("v1") @map("prompt_version")

  // Build & discovery job tracking
  buildStatus     String  @default("pending") @map("build_status") // pending | building | complete | failed
  discoveryStatus String  @default("pending") @map("discovery_status") // pending | in_progress | completed

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tripId])
  @@index([tripId, isActive])
  @@index([buildStatus])
  @@map("itineraries")
}

// ============================================================
// DiscoveredActivity — activities generated by Claude, with swipe state
// ============================================================

model DiscoveredActivity {
  id        String   @id @default(cuid())
  tripId    String   @map("trip_id")
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  profileId String?  @map("profile_id")
  profile   Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  cityId        String  @map("city_id")
  city          String
  name          String
  placeName     String? @map("place_name")
  venueType     String? @map("venue_type")
  description   String
  highlights    String[] @default([])
  category      String
  duration      String
  googleMapsUrl String? @map("google_maps_url")
  imageUrl      String? @map("image_url")

  decision  String?   // null | "liked" | "disliked"
  decidedAt DateTime? @map("decided_at")

  assignedDay   Int? @map("assigned_day")   // Global day number (matches TripDay.day)
  assignedOrder Int? @map("assigned_order") // Position within that day (1-indexed)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tripId])
  @@index([tripId, cityId])
  @@index([tripId, assignedDay])
  @@index([profileId])
  @@map("discovered_activities")
}

// ============================================================
// AffiliateClick — affiliate link click tracking
// ============================================================

model AffiliateClick {
  id    String  @id @default(uuid())
  tripId String? @map("trip_id")
  trip  Trip?   @relation(fields: [tripId], references: [id], onDelete: SetNull)

  provider    String // skyscanner | booking | getyourguide
  clickType   String @map("click_type") // flight | hotel | activity
  city        String?
  destination String?
  url         String

  userId    String? @map("user_id")
  ipHash    String? @map("ip_hash")
  metadata  Json?
  bookingConfirmed Boolean? @map("booking_confirmed")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])

  @@index([tripId])
  @@index([provider])
  @@index([createdAt])
  @@map("affiliate_clicks")
}

// ============================================================
// DiscoveredCity — cities found in AI output but missing from cities.ts
// ============================================================

model DiscoveredCity {
  id          String  @id @default(uuid())
  city        String
  country     String
  countryCode String  @map("country_code")
  lat         Float
  lng         Float

  timesProposed Int      @default(1) @map("times_proposed")
  firstTripId   String?  @map("first_trip_id")
  approved      Boolean  @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([city, countryCode], name: "city_country_unique")
  @@index([approved])
  @@map("discovered_cities")
}

// ============================================================
// FlightSelection — user-selected flights for booking cart
// ============================================================

model FlightSelection {
  id        String  @id @default(uuid())
  tripId    String  @map("trip_id")
  trip      Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  profileId String  @map("profile_id")
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  selectionType String @map("selection_type") // platform | manual
  fromIata      String @map("from_iata")
  toIata        String @map("to_iata")
  departureDate String @map("departure_date")
  direction     String // outbound | return | internal

  airline       String
  price         Float
  duration      String
  stops         Int     @default(0)
  departureTime String? @map("departure_time")
  arrivalTime   String? @map("arrival_time")
  cabin         String  @default("ECONOMY")

  bookingToken String? @map("booking_token")
  bookingUrl   String  @map("booking_url")

  booked   Boolean   @default(false)
  bookedAt DateTime? @map("booked_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tripId, fromIata, toIata, departureDate], name: "flight_selection_leg_unique")
  @@index([profileId])
  @@index([tripId])
  @@map("flight_selections")
}

// ============================================================
// HotelSelection — user-selected hotels for booking cart
// ============================================================

model HotelSelection {
  id        String  @id @default(uuid())
  tripId    String  @map("trip_id")
  trip      Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  profileId String  @map("profile_id")
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  selectionType String @map("selection_type") // platform | manual
  city          String
  countryCode   String @map("country_code")
  checkIn       String @map("check_in")
  checkOut      String @map("check_out")

  hotelName     String  @map("hotel_name")
  hotelId       String  @map("hotel_id")
  rating        Float?
  pricePerNight Float?  @map("price_per_night")
  totalPrice    Float?  @map("total_price")
  currency      String  @default("EUR")

  bookingUrl String @map("booking_url")

  booked   Boolean   @default(false)
  bookedAt DateTime? @map("booked_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tripId, city, checkIn], name: "hotel_selection_city_unique")
  @@index([profileId])
  @@index([tripId])
  @@map("hotel_selections")
}
