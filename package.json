{
  "name": "travelpro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --bail 1",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:all": "vitest run && vitest run --config vitest.config.integration.ts",
    "prepare": "husky || true",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:set-superuser": "npx tsx scripts/set-superuser.ts",
    "update-visa-data": "node scripts/generate-visa-data.js && vitest run src/data/__tests__/visa-data.test.ts",
    "download:images": "npx tsx scripts/download-city-images.ts",
    "db:sync-cities": "npx tsx scripts/sync-discovered-cities.ts",
    "arch:graph:pages-endpoints": "node --no-warnings scripts/generate-pages-endpoints-graph.ts",
    "arch:graph:endpoint-db": "node --no-warnings scripts/generate-endpoint-db-graph.ts",
    "arch:graph:full": "node --no-warnings scripts/generate-pages-endpoints-graph.ts && node --no-warnings scripts/generate-endpoint-db-graph.ts && node --no-warnings scripts/generate-page-ui-graph.ts",
    "arch:graph:pages-endpoints:baseline": "node --no-warnings scripts/generate-pages-endpoints-graph.ts --output arch/graph.pages-endpoints.baseline.json",
    "arch:graph:pages-endpoints:current": "node --no-warnings scripts/generate-pages-endpoints-graph.ts --output arch/graph.pages-endpoints.current.json",
    "arch:diff:pages-endpoints": "node --no-warnings scripts/diff-pages-endpoints-graph.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "docs:check-refs": "bash scripts/check-doc-refs.sh"
  },
  "prisma": {
    "seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.75.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@sentry/nextjs": "^10.39.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.96.0",
    "@tanstack/react-query": "^5.90.21",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "framer-motion": "^12.34.1",
    "lucide-react": "^0.574.0",
    "maplibre-gl": "^5.18.0",
    "next": "16.1.6",
    "next-route-visualizer": "^1.1.3",
    "next-sitemap": "^4.2.3",
    "pg": "^8.18.0",
    "posthog-js": "^1.350.0",
    "prisma": "^7.4.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-map-gl": "^8.1.0",
    "reactflow": "^11.11.4",
    "swr": "^2.4.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "knip": "^5.85.0",
    "lint-staged": "^16.2.7",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
