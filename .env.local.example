# ============================================================
# Travel Pro — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ── Supabase (Database + Auth) ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Recommended in production: dedicated signing secret for guest-trip owner cookies.
# If omitted, the app falls back to other server-only secrets.
GUEST_TRIP_OWNER_SECRET=replace-with-a-random-32-byte-secret
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Anthropic (AI generation, server-side only) ───────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Mapbox (map tiles) ────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# ── Upstash Redis (rate limiting + caching) ───────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── Resend (transactional email) ─────────────────────────────
RESEND_API_KEY=re_...

# ── PostHog (analytics, consent-gated) ───────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ── Sentry (error tracking) ───────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ── App URL ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── SerpApi (Google Flights prices — preferred over Amadeus) ──
# Sign up at https://serpapi.com — 100 free searches/month
# When set, flight searches use Google Flights data for accurate consumer prices.
# Booking links still go through Skyscanner affiliate.
# Falls back to Amadeus if not set.
SERPAPI_API_KEY=your-serpapi-api-key

# ── Amadeus (flight price optimization — fallback) ───────────
# Sign up at https://developers.amadeus.com/self-service
# Use "test" environment for development (sandbox, no real prices)
# Set AMADEUS_ENVIRONMENT=production + real keys for live data
AMADEUS_API_KEY=your-amadeus-api-key
AMADEUS_API_SECRET=your-amadeus-api-secret
AMADEUS_ENVIRONMENT=test   # or "production"

# ── Unsplash (city image downloads) ─────────────────────────────
# Sign up at https://unsplash.com/developers — free tier: 50 req/hour
# Run: npm run download:images
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# ── Affiliate IDs (optional, use placeholders for dev) ────────
BOOKING_AFFILIATE_ID=TRAVEL_PRO_AID
GYG_PARTNER_ID=TRAVEL_PRO_ID
