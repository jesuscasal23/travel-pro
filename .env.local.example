# ============================================================
# Travel Pro — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ── Supabase (Database + Auth) ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Recommended in production: dedicated signing secret for guest-trip owner cookies.
# If omitted, the app falls back to other server-only secrets.
GUEST_TRIP_OWNER_SECRET=replace-with-a-random-32-byte-secret
# Use the Supabase connection pooler (port 6543) for serverless deployments.
# Direct connections (port 5432) exhaust session-mode pool limits under load.
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# ── Anthropic (AI generation, server-side only) ───────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google OAuth (PWA One Tap sign-in) ──────────────────────
# Must match the Client ID configured in Supabase Dashboard → Auth → Providers → Google
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Mapbox (map tiles) ────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# ── Upstash Redis (rate limiting + caching) ───────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── Resend (transactional email) ─────────────────────────────
RESEND_API_KEY=re_...

# ── PostHog (analytics, consent-gated) ───────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
POSTHOG_API_KEY=phx_server_token
POSTHOG_HOST=https://eu.posthog.com

# ── Sentry (error tracking) ───────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ── App URL ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── SerpApi (Google Flights prices) ────────────────────────
# Sign up at https://serpapi.com — 100 free searches/month
# Flight searches use Google Flights data for accurate consumer prices.
# Booking links go through Skyscanner affiliate.
SERPAPI_API_KEY=your-serpapi-api-key

# ── Google Places (activity images) ──────────────────────────
# Enable the Places API (New) at console.cloud.google.com
GOOGLE_PLACES_API_KEY=

# ── Unsplash (city image downloads) ─────────────────────────────
# Sign up at https://unsplash.com/developers — free tier: 50 req/hour
# Run: npm run download:images
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# ── Affiliate IDs (optional, use placeholders for dev) ────────
BOOKING_AFFILIATE_ID=TRAVEL_PRO_AID
GYG_PARTNER_ID=TRAVEL_PRO_ID

# ── Stripe (payment processing) ──────────────────────────────
# Sign up at https://stripe.com — use test keys for development
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs created in the Stripe Dashboard (Products → Pricing)
STRIPE_PRICE_LIFETIME=price_...
STRIPE_PRICE_YEARLY=price_...
STRIPE_PRICE_MONTHLY=price_...
